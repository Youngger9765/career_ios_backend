# === SECRETS ONLY ===
# Copy to .env and fill in your credentials
# Other configs are in app/core/config.py

# Database (Replace with your actual credentials)
# Example format: postgresql://username:password@hostname:port/dbname
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/YOUR_DATABASE
DATABASE_URL_DIRECT=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:5432/YOUR_DATABASE

# Security
SECRET_KEY=your-secret-key-min-32-chars

# OpenAI
OPENAI_API_KEY=sk-xxx

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# GCP Billing Monitor
GCS_PROJECT=your-gcp-project-id
BILLING_DATASET_ID=billing_export
BILLING_TABLE_ID=gcp_billing_export

# Email Configuration (for billing reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
BILLING_REPORT_EMAIL=dev02@example.com

# Admin API Key (for billing endpoints)
API_ADMIN_KEY=your-secure-admin-key
